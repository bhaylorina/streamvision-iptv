<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!--
        use_controller="true"  — ExoPlayer manages its own controller internally.
        Seekbar, play/pause, rewind, fast-forward all work natively.
        Our 3 extra buttons (audio/quality/zoom) are injected via
        controller_layout_id pointing to exo_player_control_view.xml.
        The grey bar is already fixed at the Activity level (layout_marginBottom=0).
    -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        app:controller_layout_id="@layout/exo_player_control_view"
        app:resize_mode="fit"
        app:show_buffering="never"
        app:show_timeout="3000"
        app:surface_type="surface_view"
        app:use_controller="true" />

    <!-- Buffering spinner — sits on top, clickable=false so it never blocks -->
    <ProgressBar
        android:id="@+id/progress_buffering"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:clickable="false"
        android:visibility="gone" />

    <!-- Error overlay -->
    <LinearLayout
        android:id="@+id/error_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_error"
            app:tint="@color/error" />

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/error_playback"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Retry"
            app:backgroundTint="@color/primary_accent" />

    </LinearLayout>

    <!-- Channel name — shown in top-left when controls are visible -->
    <TextView
        android:id="@+id/tv_channel_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="#66000000"
        android:clickable="false"
        android:padding="8dp"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

</FrameLayout>
