<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        app:controller_layout_id="@layout/exo_player_control_view"
        app:resize_mode="fit"
        app:show_buffering="never"
        app:show_timeout="3000"
        app:surface_type="surface_view"
        app:use_controller="true" />

    <!-- Buffering spinner -->
    <ProgressBar
        android:id="@+id/progress_buffering"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:clickable="false"
        android:visibility="gone" />

    <!-- Error overlay -->
    <LinearLayout
        android:id="@+id/error_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_error"
            app:tint="@color/error" />

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/error_playback"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Retry"
            app:backgroundTint="@color/primary_accent" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         BRIGHTNESS overlay — LEFT side swipe
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/brightness_overlay"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="32dp"
        android:background="#BB000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <!-- Sun icon -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_brightness"
            android:tint="@color/white" />

        <!--
            Vertical bar built from a FrameLayout:
            - grey track (background)
            - white fill view whose height we animate in code
        -->
        <FrameLayout
            android:layout_width="10dp"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#44FFFFFF">

            <!-- Filled portion — height set programmatically 0..120dp -->
            <View
                android:id="@+id/brightness_bar"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_gravity="bottom"
                android:background="@color/white" />

        </FrameLayout>

        <!-- Percentage -->
        <TextView
            android:id="@+id/tv_brightness_pct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         VOLUME overlay — RIGHT side swipe
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/volume_overlay"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="32dp"
        android:background="#BB000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <!-- Volume icon -->
        <ImageView
            android:id="@+id/iv_volume_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_volume_up"
            android:tint="@color/white" />

        <!-- Vertical bar -->
        <FrameLayout
            android:layout_width="10dp"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#44FFFFFF">

            <!-- Filled portion -->
            <View
                android:id="@+id/volume_bar"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_gravity="bottom"
                android:background="@color/white" />

        </FrameLayout>

        <!-- Percentage -->
        <TextView
            android:id="@+id/tv_volume_pct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>
