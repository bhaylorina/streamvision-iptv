<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StreamVisionIPTV" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_accent</item>
        <item name="colorPrimaryDark">@color/primary_accent_dark</item>
        <item name="colorSecondary">@color/secondary_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:colorBackground">@color/primary_background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorTertiary">@color/text_tertiary</item>

        <item name="android:statusBarColor">@color/primary_background</item>
        <!-- FIXED: was @color/surface which caused the grey bar in the player -->
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowBackground">@color/primary_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>

        <item name="bottomNavigationStyle">@style/Widget.StreamVision.BottomNavigation</item>
    </style>

    <style name="Widget.StreamVision.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.StreamVision.BottomNavigation.ActiveIndicator</item>
    </style>

    <style name="Widget.StreamVision.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_accent</item>
    </style>

    <style name="Widget.StreamVision.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.StreamVision.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary_accent</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.StreamVision.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary_accent</item>
    </style>

    <style name="Widget.StreamVision.SearchBar" parent="Widget.Material3.SearchBar">
        <item name="android:background">@color/surface</item>
    </style>
</resources>
